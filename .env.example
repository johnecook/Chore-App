NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-or-hosted-anon-key

# Canonical public origin used in Supabase confirmation emails.
# In production, set this to your custom domain, for example: https://example.com
APP_URL=http://localhost:3000

# Server-only. Do not expose this to browser code.
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-or-hosted-service-role-key
